# Google OAuth2 Konfiguration
# ===========================
# Anleitung zum Einrichten:
#
# 1. Google Cloud Console: https://console.cloud.google.com/
# 2. Neues Projekt anlegen
# 3. "APIs & Dienste" > "Anmeldedaten" > "OAuth 2.0-Client-ID" erstellen (Typ: Webanwendung)
# 4. Autorisierte Weiterleitungs-URIs eintragen:
#      http://localhost:8080/auth/callback        (lokale Entwicklung)
#      https://deine-domain.de/auth/callback      (Produktivserver)
# 5. Diese Datei als ".env" speichern und Werte eintragen

GOOGLE_CLIENT_ID=DEINE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=DEIN_CLIENT_SECRET
REDIRECT_URI=http://localhost:8080/auth/callback

# Beliebige lange Zufallszeichenkette – geheim halten!
JWT_SECRET=hier-eine-lange-zufaellige-zeichenkette-eintragen

# Server-Konfiguration (Standardwerte für lokalen Betrieb)
DOMAIN=localhost
HTTP_PORT=8080
WS_PORT=8765
WS_URL=ws://localhost:8765
